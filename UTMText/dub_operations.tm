include: utm.tmh

:to_dub_start_from_R: |
through_sings: a/a,L .; a0/a0,L +; a1/a1,L +; [/[,R | \
        to_front_of_dub: a1/a1,L .; a0/a0,L .; g/g,R |
: g/g,L |
done:

:delete_dub: |
: 1/1,R |; 0/0,R |
del: 11/1,R .; 00/0,R .; 1/1,R |
done:

:dubify_q'1g'1i: |
q': 0/00,R .; 1/11,R |
g': 0/00,R .; 1/11,R |
i: 0/00,L |; 1/11,L |
to_front_of_dub: 11/11,L .; 00/00,L .; 1/1,R +; 0/0,R + : g/g,L |
done:
